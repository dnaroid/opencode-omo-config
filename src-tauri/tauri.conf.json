{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "OC Config",
	"version": "0.1.0",
	"identifier": "com.occonfig.desktop",
	"build": {
		"beforeDevCommand": "npm run dev",
		"beforeBuildCommand": "npm run build",
		"devUrl": "http://localhost:3101",
		"frontendDist": "../out"
	},
	"app": {
		"windows": [
			{
				"title": "OC Config",
				"width": 1200,
				"height": 820,
				"minWidth": 900,
				"minHeight": 640
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": ["app", "dmg"],
		"icon": ["icons/icon.png", "icons/icon.icns"],
		"macOS": {
			"hardenedRuntime": true
		}
	}
}
